# PostgreSQL Configuration
POSTGRES_DB=ChoreTrack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Connection Strings
# Update these in appsettings.Development.json or appsettings.json
DefaultConnection=Host=localhost;Database=ChoreTrack;Username=postgres;Password=postgres;Port=5432
Redis=localhost:6379
RabbitMQ=localhost

# JWT Configuration (copy from your appsettings.json)
# JWT__SecretKey=your_secret_key_here
# JWT__Issuer=ChoreTrackerAPI
# JWT__Audience=ChoreTrackerClient

# Email Configuration
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# AWS S3 Configuration
# AWS__S3__ProfilePictureBucket=choretrack-profile-pictures
# AWSSDK.S3.AwsAccessKeyId=your_access_key_here
# AWSSDK.S3.AwsSecretAccessKey=your_secret_key_here
